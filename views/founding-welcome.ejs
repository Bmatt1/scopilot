<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= verified ? "Welcome to Scopilot — You're a Founding Member" : "Purchase Verification — Scopilot" %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
      background: #0d0d1a;
      color: #f5f5f0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }
    .card {
      background: #1a1a2e;
      border: 1px solid #2a2a4e;
      border-radius: 8px;
      max-width: 640px;
      width: 100%;
      padding: 48px 40px;
      text-align: center;
    }
    .badge {
      display: inline-block;
      background: #c8960c;
      color: #0d0d1a;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 2px;
      margin-bottom: 24px;
    }
    .check-icon {
      width: 72px;
      height: 72px;
      background: rgba(200, 150, 12, 0.12);
      border: 2px solid #c8960c;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
      font-size: 32px;
    }
    h1 {
      font-size: 28px;
      font-weight: 800;
      color: #f5f5f0;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
    }
    .subtitle {
      color: #9a9aaa;
      font-size: 16px;
      line-height: 1.6;
      margin-bottom: 36px;
    }
    .link-card {
      background: #0d0d1a;
      border: 1px solid #2a2a4e;
      border-radius: 6px;
      padding: 20px 24px;
      margin-bottom: 16px;
      text-align: left;
    }
    .link-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #c8960c;
      margin-bottom: 8px;
    }
    .link-url {
      font-family: 'Courier New', monospace;
      font-size: 13px;
      color: #f5f5f0;
      word-break: break-all;
      background: #111128;
      padding: 10px 14px;
      border-radius: 4px;
      border: 1px solid #2a2a4e;
      display: block;
      margin-bottom: 10px;
    }
    .copy-btn {
      background: transparent;
      border: 1px solid #3a3a5e;
      color: #9a9aaa;
      font-size: 12px;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .copy-btn:hover { border-color: #c8960c; color: #c8960c; }
    .cta-primary {
      display: block;
      background: #c8960c;
      color: #0d0d1a;
      font-size: 16px;
      font-weight: 800;
      padding: 16px 32px;
      border-radius: 4px;
      text-decoration: none;
      margin-top: 32px;
      letter-spacing: 0.01em;
      transition: opacity 0.15s;
    }
    .cta-primary:hover { opacity: 0.9; }
    .cta-secondary {
      display: inline-block;
      color: #c8960c;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      margin-top: 16px;
      border-bottom: 1px solid transparent;
      transition: border-color 0.15s;
    }
    .cta-secondary:hover { border-color: #c8960c; }
    .divider {
      border: none;
      border-top: 1px solid #2a2a4e;
      margin: 32px 0;
    }
    .next-steps {
      text-align: left;
    }
    .next-steps h3 {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #5c5c6e;
      margin-bottom: 16px;
    }
    .step {
      display: flex;
      gap: 14px;
      margin-bottom: 14px;
      align-items: flex-start;
    }
    .step-num {
      background: rgba(200,150,12,0.15);
      color: #c8960c;
      font-size: 12px;
      font-weight: 800;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .step-text {
      font-size: 14px;
      color: #9a9aaa;
      line-height: 1.5;
    }
    .step-text strong { color: #f5f5f0; }
    .error-state {
      text-align: center;
    }
    .error-icon {
      font-size: 48px;
      margin-bottom: 20px;
    }
    .error-msg {
      background: rgba(200,50,50,0.1);
      border: 1px solid rgba(200,50,50,0.3);
      border-radius: 6px;
      padding: 16px 20px;
      color: #f5a0a0;
      font-size: 14px;
      margin: 16px 0 24px;
      text-align: left;
    }
    .logo {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 20px;
      font-weight: 700;
      color: #c8960c;
      margin-bottom: 40px;
      text-decoration: none;
      display: inline-block;
    }
  </style>
</head>
<body>

  <a href="/" class="logo">Scopilot</a>

  <div class="card">

    <% if (verified && contractor) { %>
      <div class="badge">Founding Member #<%= contractor.unique_slug.slice(-4).toUpperCase() %></div>

      <div class="check-icon">✓</div>

      <h1>You're in. Welcome.</h1>
      <p class="subtitle">
        Your $1,500 founding membership is confirmed.<br>
        You now have lifetime access to Scopilot — no monthly fees, ever.
      </p>

      <!-- Scoping link -->
      <div class="link-card">
        <div class="link-label">Your Homeowner Scoping Link</div>
        <code class="link-url" id="scoping-link"><%= contractor.scoping_link %></code>
        <button class="copy-btn" onclick="copyLink('scoping-link', this)">Copy Link</button>
        <p style="font-size:12px;color:#5c5c6e;margin-top:8px;">Send this to homeowners. When they scope a project, it lands in your dashboard.</p>
      </div>

      <!-- Set password / login -->
      <div class="link-card">
        <div class="link-label">Access Your Dashboard</div>
        <p style="font-size:13px;color:#9a9aaa;margin-bottom:12px;">Use the magic link below to log in and set your password:</p>
        <a href="<%= contractor.set_password_link %>" class="cta-primary" style="display:inline-block;font-size:14px;padding:12px 24px;">
          Log In & Set Password →
        </a>
      </div>

      <hr class="divider">

      <div class="next-steps">
        <h3>What to do next</h3>
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-text"><strong>Set your password</strong> — click the link above or check your email for the magic link.</div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-text"><strong>Share your scoping link</strong> — post it on your website, Google Business Profile, and social media. Homeowners click, scope their project in 5 min, and you get a qualified lead.</div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-text"><strong>Watch leads arrive</strong> — your dashboard shows every submission with project details, photos, and an estimate range. New leads also hit your inbox.</div>
        </div>
      </div>

      <a href="<%= contractor.dashboard_link %>" class="cta-primary">Go to Dashboard →</a>
      <br>
      <a href="/founding" class="cta-secondary">← Back to founding page</a>

    <% } else { %>

      <div class="error-state">
        <div class="error-icon">⚠</div>
        <h1>Payment Verification</h1>

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <p style="color:#9a9aaa;font-size:14px;margin-bottom:24px;">
          If you completed payment successfully, your account will be set up within a few minutes.
          Check your email for a welcome message from Scopilot.
        </p>

        <a href="mailto:support@polsia.com" class="cta-primary" style="display:inline-block;font-size:14px;padding:14px 28px;">
          Contact Support →
        </a>
        <br>
        <a href="/founding" class="cta-secondary">← Back to founding page</a>
      </div>

    <% } %>

  </div>

  <script>
    function copyLink(id, btn) {
      const text = document.getElementById(id).textContent.trim();
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000);
      });
    }
  </script>
</body>
</html>
