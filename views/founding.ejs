  <style>
    /* ── Reset & base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #0e0e16;
      color: #e8e8f0;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3, h4, h5 {
      font-family: 'Bricolage Grotesque', sans-serif;
      line-height: 1.1;
    }
    a { text-decoration: none; }

    /* ── Layout helpers ── */
    .page-wrap { max-width: 860px; margin: 0 auto; padding: 0 24px; }
    .page-wrap-wide { max-width: 1060px; margin: 0 auto; padding: 0 24px; }

    /* ── Topbar ── */
    .f-topbar {
      background: #0a0a12;
      border-bottom: 1px solid rgba(200,150,12,0.15);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .f-topbar-logo {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: #fff;
      letter-spacing: -0.5px;
    }
    .f-topbar-badge {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #c8960c;
      background: rgba(200,150,12,0.12);
      border: 1px solid rgba(200,150,12,0.3);
      padding: 4px 12px;
      border-radius: 3px;
    }

    /* ── CTA Buttons ── */
    .btn-gold {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 20px 44px;
      background: #c8960c;
      color: #0e0e16;
      font-size: 17px;
      font-weight: 800;
      font-family: 'Bricolage Grotesque', sans-serif;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      letter-spacing: -0.3px;
    }
    .btn-gold:hover {
      background: #daa80f;
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(200,150,12,0.4);
    }
    .btn-gold.lg {
      padding: 22px 56px;
      font-size: 19px;
    }

    /* ── Urgency bar ── */
    .urgency-bar {
      background: rgba(200,150,12,0.1);
      border-bottom: 1px solid rgba(200,150,12,0.2);
      padding: 10px 24px;
      text-align: center;
      font-size: 13px;
      font-weight: 600;
      color: #c8960c;
      letter-spacing: 0.04em;
    }
    .urgency-bar strong { color: #f5e6c0; }

    /* ── Hero ── */
    .f-hero {
      background: #0e0e16;
      padding: 80px 24px 72px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .f-hero::before {
      content: '';
      position: absolute;
      top: -120px; left: 50%;
      transform: translateX(-50%);
      width: 800px; height: 600px;
      background: radial-gradient(ellipse at center, rgba(200,150,12,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .f-hero-eyebrow {
      display: inline-block;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #c8960c;
      background: rgba(200,150,12,0.1);
      border: 1px solid rgba(200,150,12,0.25);
      padding: 6px 16px;
      border-radius: 3px;
      margin-bottom: 28px;
    }
    .f-hero-headline {
      font-size: clamp(38px, 6vw, 72px);
      font-weight: 800;
      letter-spacing: -2px;
      color: #fff;
      max-width: 780px;
      margin: 0 auto 20px;
      line-height: 1.05;
    }
    .f-hero-headline .gold { color: #c8960c; }
    .f-hero-sub {
      font-size: 19px;
      color: #9090b0;
      max-width: 580px;
      margin: 0 auto 16px;
      line-height: 1.65;
    }
    .f-hero-stat-callout {
      display: inline-block;
      background: rgba(200,150,12,0.08);
      border: 1px solid rgba(200,150,12,0.2);
      border-radius: 6px;
      padding: 12px 24px;
      font-size: 14px;
      color: #c8960c;
      margin-bottom: 40px;
    }
    .f-hero-stat-callout strong { color: #f5e6c0; }
    .f-hero-cta-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      margin-bottom: 40px;
    }
    .f-hero-cta-note {
      font-size: 13px;
      color: #6060808;
      color: rgba(150,150,180,0.7);
    }

    /* ── Spots counter ── */
    .f-spots-counter {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #141420;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      padding: 14px 28px;
      margin-bottom: 20px;
    }
    .f-spots-num {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 40px;
      font-weight: 800;
      color: #c8960c;
      letter-spacing: -1px;
      line-height: 1;
    }
    .f-spots-label {
      text-align: left;
      font-size: 13px;
      color: #8080a0;
      line-height: 1.4;
    }
    .f-spots-label strong { display: block; font-size: 15px; color: #e8e8f0; font-weight: 700; }

    /* ── Countdown ── */
    .f-countdown {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin: 0 auto 16px;
    }
    .f-countdown-unit {
      background: #141420;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 6px;
      padding: 10px 16px;
      text-align: center;
      min-width: 66px;
    }
    .f-countdown-num {
      display: block;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 30px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -1px;
      line-height: 1;
    }
    .f-countdown-label {
      display: block;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6060808;
      color: rgba(150,150,180,0.6);
      margin-top: 4px;
    }
    .f-countdown-sep {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: rgba(200,150,12,0.4);
      align-self: center;
      padding-bottom: 12px;
    }
    .f-countdown-caption {
      font-size: 12px;
      color: rgba(150,150,180,0.6);
      margin-bottom: 48px;
    }

    /* ── Section wrappers ── */
    .f-section {
      padding: 80px 24px;
    }
    .f-section-dark { background: #0a0a12; }
    .f-section-mid { background: #111119; }
    .f-section-alt { background: #0e0e16; }

    .f-section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #c8960c;
      margin-bottom: 16px;
    }
    .f-section-headline {
      font-size: clamp(30px, 4vw, 46px);
      font-weight: 800;
      letter-spacing: -1px;
      color: #fff;
      margin-bottom: 20px;
    }
    .f-section-body {
      font-size: 16px;
      color: #8080a4;
      line-height: 1.75;
      max-width: 640px;
    }
    .f-section-body p { margin-bottom: 14px; }
    .f-section-body p:last-child { margin-bottom: 0; }

    /* ── Problem section ── */
    .f-problem-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 40px;
      max-width: 640px;
    }
    .f-problem-item {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      padding: 22px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .f-problem-item:last-child { border-bottom: none; }
    .f-problem-icon {
      font-size: 24px;
      flex-shrink: 0;
      line-height: 1.2;
      margin-top: 2px;
    }
    .f-problem-text h4 {
      font-size: 17px;
      font-weight: 700;
      color: #e8e8f0;
      margin-bottom: 6px;
    }
    .f-problem-text p {
      font-size: 14px;
      color: #6060808;
      color: rgba(150,150,170,0.75);
      line-height: 1.6;
    }

    /* ── Solution ── */
    .f-solution-steps {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 660px;
      margin-top: 40px;
    }
    .f-solution-step {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      align-items: start;
    }
    .f-solution-step:last-child { border-bottom: none; }
    .f-step-num {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 42px;
      font-weight: 800;
      color: rgba(200,150,12,0.35);
      letter-spacing: -2px;
      line-height: 1;
    }
    .f-step-content h4 {
      font-size: 18px;
      font-weight: 700;
      color: #e8e8f0;
      margin-bottom: 8px;
    }
    .f-step-content p {
      font-size: 14px;
      color: rgba(150,150,170,0.75);
      line-height: 1.65;
    }

    /* ── Lead email preview mock ── */
    .f-email-mock {
      max-width: 520px;
      margin: 48px auto 0;
      background: #1a1a26;
      border: 1px solid rgba(200,150,12,0.2);
      border-radius: 10px;
      overflow: hidden;
    }
    .f-email-mock-header {
      background: #0e0e16;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .f-email-mock-dot { width: 10px; height: 10px; border-radius: 50%; }
    .f-email-mock-subject {
      font-size: 13px;
      font-weight: 600;
      color: #c8c8e0;
      margin-left: 6px;
    }
    .f-email-mock-body {
      padding: 24px 20px;
    }
    .f-email-field {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 13px;
      gap: 12px;
    }
    .f-email-field:last-child { border-bottom: none; }
    .f-email-field-key { color: rgba(150,150,180,0.6); flex-shrink: 0; }
    .f-email-field-val { color: #e8e8f0; font-weight: 600; text-align: right; }
    .f-email-photos {
      display: flex;
      gap: 8px;
      margin-top: 14px;
      background: #141420;
      padding: 12px;
      border-radius: 6px;
    }
    .f-email-photo-thumb {
      width: 64px;
      height: 52px;
      background: #2a2a38;
      border-radius: 4px;
      border: 1px solid rgba(200,150,12,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }
    .f-email-map-thumb {
      flex: 1;
      background: #1e2030;
      border-radius: 4px;
      border: 1px solid rgba(200,150,12,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      color: rgba(150,150,180,0.5);
      height: 52px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* ── Value stack ── */
    .f-value-stack {
      max-width: 680px;
      margin: 40px auto 0;
    }
    .f-value-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      gap: 16px;
    }
    .f-value-item:last-child { border-bottom: none; }
    .f-value-item-left {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .f-value-check {
      width: 22px;
      height: 22px;
      background: rgba(200,150,12,0.15);
      border: 1px solid rgba(200,150,12,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .f-value-check svg { width: 11px; height: 11px; }
    .f-value-name {
      font-size: 15px;
      font-weight: 600;
      color: #e8e8f0;
      margin-bottom: 3px;
    }
    .f-value-desc {
      font-size: 13px;
      color: rgba(150,150,180,0.6);
      line-height: 1.5;
    }
    .f-value-price {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: rgba(200,150,12,0.6);
      white-space: nowrap;
      text-align: right;
      flex-shrink: 0;
      text-decoration: line-through;
    }

    .f-value-total {
      background: #141420;
      border: 1px solid rgba(200,150,12,0.2);
      border-radius: 8px;
      padding: 24px 28px;
      margin-top: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }
    .f-value-total-label {
      font-size: 14px;
      font-weight: 700;
      color: rgba(200,150,12,0.8);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .f-value-total-struck {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: rgba(255,255,255,0.25);
      text-decoration: line-through;
      margin-bottom: 2px;
    }
    .f-value-total-price {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 42px;
      font-weight: 800;
      color: #c8960c;
      letter-spacing: -2px;
      line-height: 1;
    }
    .f-value-total-note {
      font-size: 13px;
      color: rgba(150,150,180,0.6);
      margin-top: 4px;
    }
    .f-value-cta-wrap {
      text-align: center;
      margin-top: 40px;
    }

    /* ── Math section ── */
    .f-math-box {
      background: #141420;
      border: 1px solid rgba(200,150,12,0.15);
      border-radius: 10px;
      padding: 36px 40px;
      max-width: 640px;
      margin: 40px auto 0;
    }
    .f-math-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 15px;
      gap: 16px;
    }
    .f-math-row:last-child { border-bottom: none; }
    .f-math-row .label { color: rgba(150,150,180,0.7); }
    .f-math-row .val { font-weight: 700; color: #e8e8f0; text-align: right; }
    .f-math-row .val.gold { color: #c8960c; font-family: 'Bricolage Grotesque', sans-serif; font-size: 18px; }
    .f-math-caption {
      margin-top: 28px;
      font-size: 18px;
      font-weight: 700;
      color: #e8e8f0;
      line-height: 1.5;
      text-align: center;
    }
    .f-math-caption span { color: #c8960c; }

    /* ── Scarcity section ── */
    .f-scarcity {
      padding: 80px 24px;
      text-align: center;
      background: #0a0a12;
      border-top: 1px solid rgba(200,150,12,0.1);
      border-bottom: 1px solid rgba(200,150,12,0.1);
    }
    .f-scarcity-headline {
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 800;
      letter-spacing: -1px;
      color: #fff;
      margin-bottom: 16px;
    }
    .f-scarcity-sub {
      font-size: 17px;
      color: rgba(150,150,180,0.75);
      max-width: 560px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }
    .f-scarcity-prices {
      display: flex;
      justify-content: center;
      gap: 2px;
      margin-bottom: 40px;
      flex-wrap: wrap;
    }
    .f-price-card {
      padding: 28px 36px;
      text-align: center;
      min-width: 220px;
    }
    .f-price-card.current {
      background: rgba(200,150,12,0.1);
      border: 2px solid rgba(200,150,12,0.4);
      border-radius: 8px;
    }
    .f-price-card.future {
      background: #111119;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 8px;
      opacity: 0.6;
    }
    .f-price-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }
    .f-price-card.current .f-price-label { color: #c8960c; }
    .f-price-card.future .f-price-label { color: rgba(150,150,180,0.5); }
    .f-price-amount {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 40px;
      font-weight: 800;
      letter-spacing: -2px;
      line-height: 1;
    }
    .f-price-card.current .f-price-amount { color: #c8960c; }
    .f-price-card.future .f-price-amount { color: rgba(200,200,220,0.3); }
    .f-price-freq {
      font-size: 13px;
      color: rgba(150,150,180,0.5);
      margin-top: 6px;
    }
    .f-price-card.current .f-price-freq { color: rgba(200,150,12,0.7); }

    /* ── Guarantee ── */
    .f-guarantee {
      display: flex;
      align-items: flex-start;
      gap: 28px;
      max-width: 640px;
      margin: 0 auto;
      background: #111119;
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px;
      padding: 32px 36px;
    }
    .f-guarantee-icon {
      font-size: 48px;
      flex-shrink: 0;
      line-height: 1;
    }
    .f-guarantee-title {
      font-size: 20px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 10px;
    }
    .f-guarantee-body {
      font-size: 15px;
      color: rgba(150,150,180,0.8);
      line-height: 1.7;
    }
    .f-guarantee-body strong { color: #e8e8f0; }

    /* ── FAQ ── */
    .f-faq {
      max-width: 680px;
      margin: 0 auto;
    }
    .f-faq-item {
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .f-faq-item:first-child {
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .f-faq-question {
      width: 100%;
      background: none;
      border: none;
      text-align: left;
      padding: 22px 0;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      font-family: 'DM Sans', sans-serif;
    }
    .f-faq-q-text {
      font-size: 16px;
      font-weight: 700;
      color: #e8e8f0;
      line-height: 1.4;
    }
    .f-faq-arrow {
      font-size: 20px;
      color: rgba(200,150,12,0.6);
      flex-shrink: 0;
      transition: transform 0.25s;
    }
    .f-faq-item.open .f-faq-arrow { transform: rotate(180deg); }
    .f-faq-answer {
      font-size: 15px;
      color: rgba(150,150,180,0.8);
      line-height: 1.75;
      padding-bottom: 24px;
      display: none;
    }
    .f-faq-answer strong { color: #e8e8f0; }
    .f-faq-item.open .f-faq-answer { display: block; }

    /* ── Final CTA ── */
    .f-final-cta {
      background: linear-gradient(180deg, #0a0a12 0%, #111119 100%);
