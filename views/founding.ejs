  <script>
    // ── Countdown timer ──
    // Fixed end-date for 7-day founding offer (May 29 2026 23:59:59 UTC)
    const OFFER_END = new Date('2026-05-29T23:59:59Z').getTime();

    function updateCountdown() {
      const now = Date.now();
      const diff = OFFER_END - now;

      if (diff <= 0) {
        document.getElementById('countdown').innerHTML = '<span style="color:#c8960c;font-weight:700;font-size:16px;">Offer has expired.</span>';
        return;
      }

      const days  = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const secs  = Math.floor((diff % (1000 * 60)) / 1000);

      document.getElementById('cdDays').textContent  = String(days).padStart(2, '0');
      document.getElementById('cdHours').textContent = String(hours).padStart(2, '0');
      document.getElementById('cdMins').textContent  = String(mins).padStart(2, '0');
      document.getElementById('cdSecs').textContent  = String(secs).padStart(2, '0');
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // ── Live spots counter ──
    // Polls /api/founding/spots_remaining every 60s; updates counter in place
    function updateSpotsDisplay(data) {
      if (!data || typeof data.remaining !== 'number') return;
      const el = document.getElementById('spotsNum');
      if (el) el.textContent = data.remaining;
    }

    function fetchSpots() {
      fetch('/api/founding/spots_remaining')
        .then(r => r.ok ? r.json() : null)
        .then(updateSpotsDisplay)
        .catch(() => {});
    }

    fetchSpots();
    setInterval(fetchSpots, 60_000);

    // ── Checkout ──
    async function claimFoundingSpot(btn) {
      // Track CTA click before redirect
      Scopilot.track('founding_cta_click', { location: btn.closest('section')?.className || 'unknown' });
      Scopilot._flush(); // send immediately before navigation

      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Redirecting to checkout…';

      try {
        const resp = await fetch('/api/founding/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ session_id: Scopilot._sessionId() })
        });
        const data = await resp.json();

        if (resp.status === 410) {
          // Sold out
          btn.textContent = 'Founding cohort full';
          window.location.href = '/founding/waitlist';
          return;
        }

        if (!resp.ok || !data.url) {
          alert(data.message || 'Checkout error — please try again.');
          btn.disabled = false;
          btn.textContent = originalText;
          return;
        }

        window.location.href = data.url;
      } catch (err) {
        alert('Network error — please try again.');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }

    // ── FAQ accordion ──
    function toggleFaq(btn) {
      const item = btn.closest('.f-faq-item');
      const isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.f-faq-item.open').forEach(el => el.classList.remove('open'));
      // Open this one if it wasn't already open
      if (!isOpen) item.classList.add('open');
    }
  </script>

